@page "/"

<div class="portfolio-container">
    <!-- TOP NAVIGATION -->
    <header class="navbar">
        <div class="logo">Jay Panchal</div>
        <nav>
            <a href="#work">Work</a>
            <a href="#experience">Experience</a>
        </nav>
    </header>

    <!-- HERO SECTION -->
    <section class="hero">
        <h1>Crafting reliable backend solutions.</h1>
        <p class="subtitle">Software Developer specializing in C# with a focus on system efficiency, code quality, and performance.</p>
    </section>

    <!-- WORK/PROJECTS GRID -->
    <section id="work" class="section">
        <h2 class="section-title">Selected Work</h2>
        <div class="grid">
            <div class="card">
                <h3>System Reliability</h3>
                <p>Resolved over 20 critical production defects within strict 24-hour SLAs, effectively reducing system downtime by 20%.</p>
            </div>
            <div class="card">
                <h3>Accessibility Engineering</h3>
                <p>Designed software utilizing C#, Perl, XML, and XSLT to process bank statements into accessible formats like Large Print and Braille.</p>
            </div>
            <div class="card">
                <h3>Performance Optimization</h3>
                <p>Lead code reviews and successfully refactored complex multi-threaded bugs to ensure peak system performance.</p>
            </div>
        </div>
    </section>

    <!-- MINIMALIST TIMELINE -->
    <section id="experience" class="section">
        <h2 class="section-title">Experience</h2>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-meta">2022 — Present</div>
                <div class="timeline-content">
                    <h3>Software Developer</h3>
                    <p>3 years building and maintaining reliable enterprise software.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-meta">2020 — 2022</div>
                <div class="timeline-content">
                    <h3>Overnight Fulfillment Associate</h3>
                    <p>Walmart</p>
                </div>
            </div>
        </div>
    </section>
</div>